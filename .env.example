# Copy to .env and fill in. Never commit .env.
OPENAI_API_KEY=
# Host-side default; inside docker compose the app service overrides this.
DATABASE_URL=postgresql://finquery:finquery@localhost:5433/finquery

# PII gate at every LLM boundary (true = pseudonymize, false = raw; ablation switch).
# After flipping, re-run: python -m ingest.serialize_transactions
PII_MASKING=true

# KB retrieval leg for search_finance_kb: sparse | dense | hybrid.
# sparse is key-free; switch to hybrid after: python -m ingest.embed_chunks
KB_RETRIEVAL_MODE=sparse
